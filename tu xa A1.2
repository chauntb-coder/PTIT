<script>
  const NUM_MCQ = 30;

  function normalize(str) {
    return (str || '').toString().trim().toUpperCase();
  }

  function processExcel() {
    const fileInput = document.getElementById('excelFile');
    const file = fileInput.files[0];
    const msg = document.getElementById('message');
    const resultDiv = document.getElementById('result');
    msg.textContent = '';
    resultDiv.textContent = '';

    if (!file) {
      msg.textContent = 'Vui lòng chọn file Excel tổng hợp.';
      return;
    }

    const reader = new FileReader();

    reader.onload = function(e) {
      try {
        const data = new Uint8Array(e.target.result);
        const workbook = XLSX.read(data, { type: 'array' });
        const sheetName = workbook.SheetNames[0];
        const sheet = workbook.Sheets[sheetName];
        const rows = XLSX.utils.sheet_to_json(sheet, { header: 1 });

        if (rows.length < 7) {
          msg.textContent = 'File quá ngắn, không đủ dữ liệu đáp án và sinh viên.';
          return;
        }

        // ================== PHẦN ĐÁP ÁN ==================
        const answerHeaderRow = 0; // Excel row 1
        const answerStartRow = 1;  // Excel row 2
        const answerEndRow   = 4;  // Excel row 5 (4 mã đề: 032, 033, 034, 031)

        const answerKeys = {}; // { code: "ABCD..." }

        const header = rows[answerHeaderRow] || [];
        let codeColIndex = -1;
        for (let i = 0; i < header.length; i++) {
          const v = normalize(header[i]);
          if (v === 'MÃ ĐỀ' || v === 'MA ĐỀ' || v === 'MA DE') {
            codeColIndex = i;
            break;
          }
        }

        if (codeColIndex === -1) {
          msg.textContent = 'Không tìm thấy cột "Mã Đề" trong phần đáp án (hàng 1).';
          return;
        }

        const firstAnswerCol = codeColIndex + 1;

        for (let r = answerStartRow; r <= answerEndRow && r < rows.length; r++) {
          const row = rows[r];
          if (!row || row.length === 0) continue;

          const code = normalize(row[codeColIndex]);
          if (!code) continue;

          const answers = [];
          let col = firstAnswerCol;
          while (answers.length < NUM_MCQ && col < row.length) {
            const ans = normalize(row[col]);
            if (ans) answers.push(ans);
            col += 2; // bỏ cột Điểm
          }

          answerKeys[code] = answers.join('');
        }

        if (Object.keys(answerKeys).length === 0) {
          msg.textContent = 'Không đọc được đáp án cho các mã đề (hàng 2–5).';
          return;
        }

        // ================== PHẦN SINH VIÊN ==================
        const studentStartRow = 6; // Excel row 7

        const results = [];
        for (let r = studentStartRow; r < rows.length; r++) {
          const row = rows[r];
          if (!row || row.length === 0) continue;

          // cột 2: SBD, cột 4: Mã Đề (theo hình: A=STT, B=Họ tên, C=SBD, D=Điểm, E=Mã Đề)
          const studentId = (row[2] || '').toString().trim();
          const code = normalize(row[4]);

          if (!studentId || !code) continue;

          const key = answerKeys[code];
          if (!key) {
            results.push({
              studentId,
              code,
              correct: null,
              total: NUM_MCQ,
              percent: '',
              error: 'Không tìm thấy đáp án cho mã đề ' + code
            });
            continue;
          }

          const stuAnswers = [];
          let col = 5; // cột sau Mã Đề
          while (stuAnswers.length < NUM_MCQ && col < row.length) {
            const ans = normalize(row[col]);
            if (ans) stuAnswers.push(ans);
            col += 2; // bỏ cột Điểm
          }

          const studentString = stuAnswers.join('');

          if (studentString.length !== key.length) {
            results.push({
              studentId,
              code,
              correct: null,
              total: NUM_MCQ,
              percent: '',
              error:
                'Số câu đọc được: ' + studentString.length +
                ', số câu đáp án: ' + key.length
            });
            continue;
          }

          let correct = 0;
          for (let i = 0; i < key.length; i++) {
            if (key[i] === studentString[i]) correct++;
          }
          const total = NUM_MCQ;
          const percent = total > 0 ? (correct / total) * 100 : 0;

          results.push({
            studentId,
            code,
            correct,
            total,
            percent: percent.toFixed(2) + '%',
            error: ''
          });
        }

        renderResult(results);
      } catch (err) {
        console.error(err);
        msg.textContent = 'Có lỗi khi xử lý file. Vui lòng kiểm tra lại cấu trúc file.';
      }
    }

    function renderResult(results) {
      const resultDiv = document.getElementById('result');

      if (!results || results.length === 0) {
        resultDiv.textContent = 'Không có bản ghi sinh viên hợp lệ.';
        return;
      }

      let html = '<table><thead><tr>' +
        '<th>STT</th>' +
        '<th>SBD</th>' +
        '<th>Mã đề</th>' +
        '<th>Số câu đúng (trên 30)</th>' +
        '<th>30</th>' +
        '<th>% đúng</th>' +
        '<th>Ghi chú</th>' +
        '</tr></thead><tbody>';

      results.forEach((r, index) => {
        html += '<tr>' +
          '<td>' + (index + 1) + '</td>' +
          '<td>' + (r.studentId || '') + '</td>' +
          '<td>' + (r.code || '') + '</td>' +
          '<td>' + (r.correct != null ? r.correct : '') + '</td>' +
          '<td>' + (r.total != null ? r.total : '') + '</td>' +
          '<td>' + (r.percent || '') + '</td>' +
          '<td>' + (r.error || '') + '</td>' +
          '</tr>';
      });

      html += '</tbody></table>';
      resultDiv.innerHTML = html;
    }
</script>
