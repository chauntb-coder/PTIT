<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>Tính điểm trắc nghiệm (nhiều sinh viên)</title>
  <style>
    body { font-family: sans-serif; max-width: 1000px; margin: 20px auto; }
    textarea { width: 100%; height: 80px; font-family: monospace; }
    label { font-weight: bold; }
    .result { margin-top: 10px; font-size: 16px; }
    .error { color: red; }
    table { border-collapse: collapse; width: 100%; margin-top: 10px; }
    th, td { border: 1px solid #ccc; padding: 4px 6px; font-size: 13px; text-align: center; }
    th { background: #f0f0f0; }
  </style>

  <!-- SheetJS để đọc Excel trên trình duyệt -->
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
</head>
<body>
  <h2>Tính số câu đúng trắc nghiệm cho nhiều sinh viên</h2>

  <!-- 1. Upload file đáp án -->
  <h3>1. Upload file đáp án (CSV/TXT)</h3>
  <p>
    File đáp án dạng CSV/TXT, mỗi dòng:<br>
    <code>mã_đề,đáp án câu 1,đáp án câu 2,...</code><br>
    Ví dụ: <code>100,C,B,A,D,B,C,...</code>
  </p>

  <input type="file" id="answerFile" accept=".csv,.txt">
  <button onclick="loadAnswerFile()">Đọc file đáp án</button>

  <div id="fileMessage" class="error"></div>

  <div id="answerPreview" class="result"></div>

  <hr>

  <!-- 2. Upload file sinh viên -->
  <h3>2. Upload file câu trả lời sinh viên (Excel/CSV)</h3>
  <p>
    File Excel/CSV, mỗi dòng (bỏ qua dòng header đầu tiên):<br>
    Cột 1: Student ID, Cột 2: Mã đề, Cột 3 trở đi: đáp án từng câu (Q1, Q2, ...).<br>
    Ví dụ: <code>SV001,100,C,B,C,D,...</code>
  </p>

  <input type="file" id="studentFile" accept=".xlsx,.xls,.csv">
  <button onclick="loadStudentFile()">Đọc file sinh viên &amp; chấm điểm</button>

  <div id="studentFileMessage" class="error"></div>

  <div id="classResult" class="result"></div>

  <script>
    // Lưu đáp án chuẩn: { code: "ABCD..." }
    let answerKeys = {};

    function normalize(str) {
      return (str || '').toString().replace(/\s+/g, '').toUpperCase();
    }

    /* ==================== ĐỌC FILE ĐÁP ÁN ==================== */

    function loadAnswerFile() {
      const input = document.getElementById('answerFile');
      const file = input.files[0];
      const msg = document.getElementById('fileMessage');
      const preview = document.getElementById('answerPreview');
      msg.textContent = '';
      preview.textContent = '';
      answerKeys = {};

      if (!file) {
        msg.textContent = 'Vui lòng chọn file đáp án.';
        return;
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        const text = e.target.result;
        parseAnswerFile(text);
      };
      reader.onerror = function() {
        msg.textContent = 'Không đọc được file đáp án.';
      };
      reader.readAsText(file, 'UTF-8');
    }

    function parseAnswerFile(text) {
      const msg = document.getElementById('fileMessage');
      const preview = document.getElementById('answerPreview');
      answerKeys = {};

      const lines = text.split(/\r?\n/).filter(line => line.trim().length > 0);

      lines.forEach(line => {
        // tách theo dấu phẩy, chấm phẩy hoặc tab
        const parts = line.split(/[,;\t]/).map(p => p.trim());
        if (parts.length < 2) return;

        const code = parts[0];
        const answers = parts
          .slice(1)
          .join('')          // ghép thành chuỗi
          .replace(/\s+/g, '')
          .toUpperCase();

        if (code && answers.length > 0) {
          answerKeys[code] = answers;
        }
      });

      const codes = Object.keys(answerKeys);

      if (codes.length === 0) {
        msg.textContent = 'Không tìm thấy dòng dữ liệu hợp lệ trong file đáp án.';
        preview.textContent = '';
      } else {
        msg.textContent = '';
        let html = 'Đã đọc ' + codes.length + ' mã đề:<br>';
        html += codes.map(code =>
          code + ' (' + answerKeys[code].length + ' câu)'
        ).join('<br>');
        preview.innerHTML = html;
      }
    }

    /* ==================== ĐỌC FILE SINH VIÊN ==================== */

    function loadStudentFile() {
      const fileInput = document.getElementById('studentFile');
      const file = fileInput.files[0];
      const msg = document.getElementById('studentFileMessage');
      const resultDiv = document.getElementById('classResult');
      msg.textContent = '';
      resultDiv.textContent = '';

      if (Object.keys(answerKeys).length === 0) {
        msg.textContent = 'Chưa có đáp án chuẩn. Hãy upload file đáp án trước.';
        return;
      }

      if (!file) {
        msg.textContent = 'Vui lòng chọn file câu trả lời sinh viên.';
        return;
      }

      const reader = new FileReader();

      reader.onload = function(e) {
        const data = new Uint8Array(e.target.result);
        // Đọc Excel/CSV bằng SheetJS
        const workbook = XLSX.read(data, { type: 'array' });
        const sheetName = workbook.SheetNames[0];
        const sheet = workbook.Sheets[sheetName];

        // Lấy dữ liệu dạng array-of-arrays
        const rows = XLSX.utils.sheet_to_json(sheet, { header: 1 });

        if (rows.length <= 1) {
          msg.textContent = 'File sinh viên không có dữ liệu (hoặc chỉ có header).';
          return;
        }

        // Bỏ dòng đầu tiên (header)
        const dataRows = rows.slice(1);

        // Chấm điểm từng sinh viên
        const results = [];
        dataRows.forEach((row, idx) => {
          // row: [student_id, code, Q1, Q2, ...]
          const studentId = (row[0] || '').toString().trim();
          const code = (row[1] || '').toString().trim();
          if (!studentId || !code) return; // bỏ dòng thiếu thông tin

          const answersArray = row.slice(2).map(x => normalize(x));
          const studentString = answersArray.join('');

          const key = answerKeys[code];
          if (!key) {
            results.push({
              studentId,
              code,
              error: 'Không tìm thấy mã đề ' + code + ' trong file đáp án.'
            });
            return;
          }

          if (studentString.length !== key.length) {
            results.push({
              studentId,
              code,
              error:
                'Số câu sinh viên: ' + studentString.length +
                ', số câu đề: ' + key.length
            });
            return;
          }

          let correct = 0;
          for (let i = 0; i < key.length; i++) {
            if (key[i] === studentString[i]) correct++;
          }
          const total = key.length;
          const percent = total > 0 ? (correct / total) * 100 : 0;

          results.push({
            studentId,
            code,
            correct,
            total,
            percent: percent.toFixed(2) + '%',
            error: ''
          });
        });

        renderClassResult(results);
      };

      reader.onerror = function() {
        msg.textContent = 'Không đọc được file sinh viên.';
      };

      // Đọc file dạng binary để SheetJS xử lý
      reader.readAsArrayBuffer(file);
    }

    function renderClassResult(results) {
      const resultDiv = document.getElementById('classResult');

      if (!results || results.length === 0) {
        resultDiv.textContent = 'Không có bản ghi sinh viên hợp lệ.';
        return;
      }

      let html = '<table><thead><tr>' +
        '<th>STT</th>' +
        '<th>Student ID</th>' +
        '<th>Mã đề</th>' +
        '<th>Số câu đúng</th>' +
        '<th>Tổng số câu</th>' +
        '<th>Tỉ lệ đúng</th>' +
        '<th>Ghi chú</th>' +
        '</tr></thead><tbody>';

      results.forEach((r, index) => {
        html += '<tr>' +
          '<td>' + (index + 1) + '</td>' +
          '<td>' + (r.studentId || '') + '</td>' +
          '<td>' + (r.code || '') + '</td>' +
          '<td>' + (r.correct != null ? r.correct : '') + '</td>' +
          '<td>' + (r.total != null ? r.total : '') + '</td>' +
          '<td>' + (r.percent || '') + '</td>' +
          '<td>' + (r.error || '') + '</td>' +
          '</tr>';
      });

      html += '</tbody></table>';
      resultDiv.innerHTML = html;
    }
  </script>
</body>
</html>
